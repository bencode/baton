# baton back-office docker stack — copy to `.env` and fill in. `.env` is gitignored.
COMPOSE_PROJECT_NAME=baton

# Host port the internal caddy listens on; the machine-i caddy proxies the domain here.
CADDY_HOST_PORT=5600

NODE_ENV=production
PORT=3280

# SQLite file on the baton_data volume (persists across restarts/redeploys).
DATABASE_URL=file:/data/baton.db

# REQUIRED in prod — signs the session cookie. Generate with: openssl rand -hex 32
BATON_AUTH_SECRET=

# Optional: create this admin login on first `seed` (else use `seed:user` manually).
# BATON_SEED_USER=admin
# BATON_SEED_PASS=change-me

# ── DingTalk bridge (the `bridge` service) ────────────────────────────
# Leave the DINGTALK_* blank to not run the bridge meaningfully.
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
# Internal API (same compose network); deep-link base is the public URL.
BATON_SERVER=http://backend:3280
BATON_WEB_BASE=https://baton.fmap.dev
# Bridge logs in (auth is on) — reuse the admin login.
BATON_USER=admin
BATON_PASS=
# Route every DingTalk message to this (project, worker).
BATON_PROJECT_ID=2
BATON_WORKER_ID=1
# Optional: prompt template to invoke a skill, e.g. "…请用 xxx 技能处理。"
# DINGTALK_PROMPT_TEMPLATE=收到钉钉消息(来自 {sender}):\n\n{text}
