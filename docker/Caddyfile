# Internal caddy for the baton stack (HTTP only; TLS is the outer machine-i caddy).
# One listener serves the SPA and proxies the API. The outer caddy reverse-proxies
# baton.fmap.dev → this container's published ${CADDY_HOST_PORT}.
:80 {
	# Compress the API JSON (multi-MB session transcripts) and the SPA bundle —
	# EXCEPT the streaming endpoints: SSE (paths ending in /stream) and the terminal
	# WebSocket (ending in /ws). `encode` buffers, which would break the real-time
	# flush `flush_interval -1` preserves; and it has no business wrapping a hijacked
	# WS upgrade. reverse_proxy itself forwards the WS upgrade automatically.
	@compressible not path */stream */ws
	encode @compressible zstd gzip

	# /api/* → backend. `handle_path` STRIPS the /api prefix (baton routes are flat,
	# e.g. /sessions, /auth — the dev Vite proxy strips it too). flush_interval -1
	# keeps SSE / streaming responses unbuffered.
	handle_path /api/* {
		reverse_proxy backend:3280 {
			flush_interval -1
		}
	}

	# SPA: serve built assets, fall back to index.html for client-side routes.
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
