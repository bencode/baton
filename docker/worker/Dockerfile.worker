# baton worker — runs a claude-code agent inside a Linux container (colima on a
# Mac). The published @lesscap/baton-cli daemon (`baton worker run`) drives
# remote baton sessions; each turn spawns `claude` in a git worktree off /repo.
# The container is the security boundary: claude runs --dangerously-skip-
# permissions, but can only touch the mounted repo + volumes.
#
# claude auth is env-based (Anthropic-compatible proxy): ANTHROPIC_BASE_URL +
# ANTHROPIC_AUTH_TOKEN (and/or ANTHROPIC_API_KEY), set via .env. Modeled on
# trantor/tcollab's Dockerfile.server.
FROM node:26-bookworm-slim

ARG CLAUDE_CODE_VERSION=2.1.159
ARG BATON_CLI_VERSION=0.4.2
# Set to a non-empty value to bake in the reclaude CLI (a claude wrapper that
# routes through the reclaude.ai gateway). Point BATON_CLAUDE_BIN at it in .env
# to drive claude through reclaude instead of an Anthropic-compatible endpoint.
ARG INSTALL_RECLAUDE=

# build-essential (+ python3) lets node-pty rebuild from source: Node 26 ships a
# broken prebuilt (pty.node loads but spawn-helper fails), so @baton/cli's
# postinstall falls back to `npm rebuild node-pty --build-from-source` — which
# needs a C++ toolchain. Without it, interactive terminals are silently disabled.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git ca-certificates curl ripgrep jq less python3 build-essential procps \
    && rm -rf /var/lib/apt/lists/*

# Non-root agent user (reuse uid 1000; the slim image's `node` user holds it).
RUN userdel -r node 2>/dev/null || true \
    && useradd -m -s /bin/bash -u 1000 baton

USER baton
WORKDIR /home/baton
ENV HOME=/home/baton \
    PATH=/home/baton/.npm-global/bin:/home/baton/.erda/bin:/usr/local/bin:/usr/bin:/bin

# claude-code ships its native binary as a per-arch optional dep
# (@anthropic-ai/claude-code-<platform>). npm's optional-dep resolution can
# silently skip it → `claude: not found`. Install the linux-arm64 package
# explicitly so a missing native binary fails the build instead of producing a
# usable-looking but broken image. (Switch to linux-x64 for an amd64 host.)
RUN mkdir -p /home/baton/.npm-global \
    && npm config set prefix /home/baton/.npm-global \
    && npm i -g \
      "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
      "@anthropic-ai/claude-code-linux-arm64@${CLAUDE_CODE_VERSION}" \
      "@lesscap/baton-cli@${BATON_CLI_VERSION}" \
      esbuild \
    && claude --version && command -v baton >/dev/null && command -v esbuild >/dev/null

# reclaude (optional, ARG INSTALL_RECLAUDE) — a claude wrapper that authenticates
# via the reclaude.ai gateway. Installs the binary to ~/.local/bin/reclaude; the
# claude CLI it drives is fetched at first runtime into ~/.reclaude/claude-cli
# (persisted on the .reclaude volume, so it downloads once). Device login is a
# one-time interactive step against that volume — see README.
RUN if [ -n "$INSTALL_RECLAUDE" ]; then \
      curl -fsSL https://reclaude.ai/install.sh | bash \
      && test -x /home/baton/.local/bin/reclaude; \
    fi

# erda-cli — for trantor-fe-mr (erda.cloud merge requests). install.sh only
# ships linux/amd64 today; on arm64 there's no release, so this is BEST-EFFORT
# (skip, don't fail the build). On arm64 hosts the MR-create step runs
# off-worker (erda web, or an amd64 host); push itself uses native git.
# Login deferred to runtime (`erda-cli login -u $ERDA_USERNAME -p $ERDA_PASSWORD`).
RUN curl -fsSL https://raw.githubusercontent.com/erda-project/erda/master/tools/cli/install.sh -o /tmp/erda-install.sh \
    && (bash /tmp/erda-install.sh alpha && erda-cli version \
        || echo "WARN: erda-cli unavailable for $(uname -m) — MR-create runs off-worker") \
    && rm -f /tmp/erda-install.sh

# git identity for commits made inside spawned worktrees (else first commit
# errors "Author identity unknown"). Push creds (only if the agent pushes) via
# credential.helper store; the deploy host mounts /home/baton/.gitcfg/ as a
# directory holding a `credentials` file (one line: https://USER:TOKEN@host).
RUN git config --global user.name "baton" \
    && git config --global user.email "baton@lesscap.local" \
    && git config --global credential.helper "store --file=/home/baton/.gitcfg/credentials"

# Pre-create the dirs that get named-volume mounts, owned by `baton`. Docker
# seeds a fresh volume from the image path's ownership — without this, the
# mount point is created root-owned and the non-root user can't write
# (EACCES on ~/.local/share/baton/machine-id).
# Seed claude settings too (no Co-Authored-By trailer); fresh volume copies it in.
RUN mkdir -p /home/baton/.claude /home/baton/.local/share/baton /home/baton/.reclaude \
    && printf '{\n  "includeCoAuthoredBy": false,\n  "theme": "dark"\n}\n' \
      > /home/baton/.claude/settings.json

COPY --chown=baton:baton entrypoint.sh /home/baton/entrypoint.sh
RUN chmod +x /home/baton/entrypoint.sh

WORKDIR /repo
ENTRYPOINT ["/home/baton/entrypoint.sh"]
