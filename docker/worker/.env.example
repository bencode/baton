# baton worker (container) — copy to .env and fill in. .env is gitignored.

# --- baton wiring -----------------------------------------------------------
BATON_URL=https://baton.fmap.dev/api
BATON_PROJECT_ID=2
WORKER_NAME=macmini

# Host repo the agent works in (mounted to /repo). Worktrees branch off its
# .git; the agent's changes land on `baton/<code>` branches you can inspect.
BATON_REPO_DIR=/Users/bencode/trantor-daily

# --- claude auth (Anthropic-compatible proxy — your reclaude values) --------
# Set the proxy endpoint + token. Use AUTH_TOKEN for bearer-style proxies, or
# API_KEY for key-style; leave the unused one empty.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
