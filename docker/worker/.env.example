# baton worker (container) — copy to .env and fill in. .env is gitignored.

# --- baton wiring -----------------------------------------------------------
BATON_URL=https://baton.fmap.dev/api
BATON_PROJECT_ID=2
WORKER_NAME=macmini
# claude-code or codex. The entrypoint re-registers idempotently on each start,
# so changing this updates the existing worker row.
BATON_AGENT_KIND=claude-code

# Host repo the agent works in (mounted to /repo). Worktrees branch off its
# .git; the agent's changes land on `baton/<code>` branches you can inspect.
BATON_REPO_DIR=/Users/bencode/trantor-daily

# --- claude auth ------------------------------------------------------------
# Option 1 — Anthropic-compatible proxy (e.g. a hosted gateway). Set the proxy
# endpoint + token. Use AUTH_TOKEN for bearer-style, or API_KEY for key-style;
# leave the unused one empty.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=

# Option 2 — reclaude (a claude wrapper using the reclaude.ai gateway). Build the
# image with --build-arg INSTALL_RECLAUDE=1, mount a named volume at
# /home/baton/.reclaude (device login + claude cache), leave ANTHROPIC_* empty,
# and point baton at the reclaude binary. One-time `reclaude login` inside the
# running container — see README "claude via reclaude (baked into the image)".
# BATON_CLAUDE_BIN=/home/baton/.local/bin/reclaude

# --- codex auth -------------------------------------------------------------
# For ChatGPT-plan auth, keep the codex_home volume mounted and run once:
#   docker compose -f worker-compose.yml exec worker codex login
# For API-key auth, configure Codex according to your OpenAI/Codex setup, e.g.
# by providing the relevant OPENAI_* environment variables here.
# OPENAI_API_KEY=

# --- second worker from the SAME repo dir (optional) ------------------------
# To run a second worker beside the first (same /repo, different identity),
# copy this dir, then in that .env set a distinct project name + config path:
# COMPOSE_PROJECT_NAME=baton-worker-pro    # own volumes + container names
# BATON_WORKER_CONFIG=/home/baton/.local/share/baton/config.json  # own .baton.json
#   (entrypoint.sh passes this to the CLI as `--config`; baton ignores the env)
