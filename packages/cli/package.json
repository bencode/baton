{
  "name": "@lesscap/baton-cli",
  "version": "0.2.8",
  "license": "MIT",
  "type": "module",
  "description": "baton CLI — register/run a worker, manage projects/requirements/tasks/sessions",
  "bin": {
    "baton": "./dist/baton.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "baton": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=bundle --external:@anthropic-ai/claude-agent-sdk --banner:js=\"#!/usr/bin/env node\" --outfile=dist/baton.mjs && chmod +x dist/baton.mjs",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "devDependencies": {
    "@baton/shared": "workspace:*",
    "@types/node": "^25.9.1",
    "citty": "^0.2.2",
    "esbuild": "^0.28.0",
    "eventsource": "^4.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.161"
  }
}
