// baton persistence (M1, SQLite via Prisma). Collaboration dimension only: Workspace / Project / Requirement / Task.
// PKs are INT autoincrement; Requirement/Task carry a project-scoped human code (R-N / T-N). The
// next number per kind lives in CodeCounter rows so Project's domain stays free of counter state.
// Array/object fields are stored as JSON text, (de)serialized by the Store mapping layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  projects Project[]
}

model Project {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  name        String
  description String?
  createdAt   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requirements Requirement[]
  tasks        Task[]
  sessions     Session[]
  assignments  Assignment[]
  counters     CodeCounter[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model CodeCounter {
  projectId Int
  kind      String // 'requirement' | 'task' | 'session' | 'assignment' (open-ended; created on demand)
  next      Int    @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, kind])
}

model Requirement {
  id          Int      @id @default(autoincrement())
  projectId   Int
  code        String   // 'R-1', 'R-2', ...
  title       String
  description String?
  resources   String   @default("[]") // JSON ResourceRef[]
  tags        String   @default("[]") // JSON string[]
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([status])
}

model Task {
  id            Int      @id @default(autoincrement())
  requirementId Int
  projectId     Int      // denorm to enable DB-level (projectId, code) UNIQUE
  code          String   // 'T-1', 'T-2', ...
  title         String
  spec          String?
  requires      String   @default("[]") // JSON string[]
  dependsOn     String   @default("[]") // JSON Id[] (int FK references)
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requirement Requirement  @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@unique([projectId, code])
  @@index([requirementId])
  @@index([projectId])
  @@index([status])
}

// A long-lived worker presence: registered once, then heartbeats + claims tasks.
// apiToken is the bearer credential issued at registration; not exposed in domain JSON.
model Session {
  id           Int       @id @default(autoincrement())
  projectId    Int
  code         String // 'S-N'
  mode         String // 'worker' | 'skill'
  name         String
  capabilities String    @default("[]") // JSON string[]
  apiToken     String    @unique
  status       String // 'active' | 'idle' | 'closed'
  startedAt    DateTime  @default(now())
  heartbeatAt  DateTime  @default(now())
  closedAt     DateTime?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([status])
}

// One execution of a Task by a Session. Lifecycle: running → done | failed | abandoned.
model Assignment {
  id        Int       @id @default(autoincrement())
  projectId Int
  code      String // 'A-N'
  sessionId Int
  taskId    Int
  status    String // 'running' | 'done' | 'failed' | 'abandoned'
  result    String?
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  task    Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  events  AssignmentEvent[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([sessionId])
  @@index([taskId])
  @@index([status])
}

// Opaque SDK event envelope. baton stores payload as JSON without interpreting.
// sequence is monotonic per assignment (assigned by the worker).
model AssignmentEvent {
  id           Int      @id @default(autoincrement())
  assignmentId Int
  sequence     Int
  payload      String // JSON
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, sequence])
  @@index([assignmentId])
}
