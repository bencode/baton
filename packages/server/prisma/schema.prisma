// baton persistence (M1, SQLite via Prisma). Collaboration dimension only: Workspace / Project / Requirement / Task.
// PKs are INT autoincrement; Requirement/Task carry a project-scoped human code (R-N / T-N). The
// next number per kind lives in CodeCounter rows so Project's domain stays free of counter state.
// Array/object fields are stored as JSON text, (de)serialized by the Store mapping layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  projects Project[]
}

model Project {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  name        String
  description String?
  createdAt   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requirements Requirement[]
  tasks        Task[]
  sessions     Session[]
  workers      Worker[]
  counters     CodeCounter[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model CodeCounter {
  projectId Int
  kind      String // 'requirement' | 'task' | 'session' | 'assignment' (open-ended; created on demand)
  next      Int    @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, kind])
}

model Requirement {
  id          Int      @id @default(autoincrement())
  projectId   Int
  code        String // 'R-1', 'R-2', ...
  title       String
  description String?
  resources   String   @default("[]") // JSON ResourceRef[]
  tags        String   @default("[]") // JSON string[]
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([status])
}

model Task {
  id            Int      @id @default(autoincrement())
  requirementId Int
  projectId     Int // denorm to enable DB-level (projectId, code) UNIQUE
  code          String // 'T-1', 'T-2', ...
  title         String
  spec          String?
  dependsOn     String   @default("[]") // JSON Id[] (int FK references)
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([requirementId])
  @@index([projectId])
  @@index([status])
}

// A Session models one Claude Code conversation. claudeSessionId is a UUID
// baton generates at creation time; the server passes it as --session-id on
// the first turn and --resume on subsequent turns. worktreePath is a git
// worktree provisioned by the CLI at `baton session new`.
//
// `state` (idle/busy/closed) and `heartbeatAt` from M2.5 are gone — busy is
// derived from SessionEvent log, alive from worker liveness via machineId.
// `code` (S-N) is dropped: Session isn't chat-referenced like R-/T- are, so
// int id + human name is enough. machineId/hostname/workerName are snapshots
// (strings, no FK) that group sessions in the UI.
model Session {
  id              Int       @id @default(autoincrement())
  projectId       Int
  mode            String // 'worker' | 'skill'
  name            String
  apiToken        String    @unique
  claudeSessionId String?   @unique
  worktreePath    String?
  machineId       String?
  hostname        String?
  workerName      String?
  startedAt       DateTime  @default(now())
  closedAt        DateTime?

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events  SessionEvent[]

  @@index([projectId])
  @@index([machineId])
}

// A Worker is a (project × machine) registration. machineId is a UUID baton
// lazily writes to ~/.local/share/baton/machine-id on the client. name is
// the human handle. No code (W-N) and no apiToken — heartbeat is unauth in
// v0 (single-team dev environment). Worker rows persist; alive/lastSeen
// belong in memory.
model Worker {
  id        Int       @id @default(autoincrement())
  projectId Int
  machineId String
  name      String
  hostname  String
  startedAt DateTime  @default(now())
  closedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, machineId])
  @@index([projectId, name])
}

// Append-only chat / SDK event log per session. processedAt only meaningful
// for type='user_message': null until the spawning turn finishes.
// type ∈ 'user_message' | 'sdk_event' | 'turn_complete' | 'turn_error' | 'system'.
model SessionEvent {
  id          Int       @id @default(autoincrement())
  sessionId   Int
  sequence    Int
  type        String
  payload     String // JSON
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId])
  @@index([sessionId, processedAt])
}
