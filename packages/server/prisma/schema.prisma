// baton persistence (M1, SQLite via Prisma). Collaboration dimension only: Workspace / Project / Requirement / Task.
// PKs are INT autoincrement; Requirement/Task carry a project-scoped human code (R-N / T-N). The
// next number per kind lives in CodeCounter rows so Project's domain stays free of counter state.
// Array/object fields are stored as JSON text, (de)serialized by the Store mapping layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  projects Project[]
}

model Project {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  name        String
  description String?
  createdAt   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requirements Requirement[]
  tasks        Task[]
  sessions     Session[]
  workers      Worker[]
  counters     CodeCounter[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model CodeCounter {
  projectId Int
  kind      String // 'requirement' | 'task' — Session no longer has a code (int id only)
  next      Int    @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, kind])
}

model Requirement {
  id          Int      @id @default(autoincrement())
  projectId   Int
  code        String // 'R-1', 'R-2', ...
  title       String
  description String?
  resources   String   @default("[]") // JSON ResourceRef[]
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([status])
}

model Task {
  id            Int      @id @default(autoincrement())
  requirementId Int
  projectId     Int // denorm to enable DB-level (projectId, code) UNIQUE
  code          String // 'T-1', 'T-2', ...
  title         String
  spec          String?
  dependsOn     String   @default("[]") // JSON Id[] (int FK references)
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([requirementId])
  @@index([projectId])
  @@index([status])
}

// A Session models one agent conversation, physically pinned to a Worker
// (= a specific machine) and to that machine's agent session file. The pinning
// is non-movable: `claude --resume <agentSessionId>` only works on the worker
// where the agent session file was first created (~/.claude/projects/...).
//
// agentKind is the agent flavour (currently 'claude-code'; 'codex' etc. later);
// agentSessionId is the agent's own session reference (a UUID for claude-code).
//
// `state` (idle/busy/closed) and `heartbeatAt` from M2.5 are gone — busy is
// derived from SessionEvent log, alive from worker liveness. `code` (S-N) is
// dropped: Session isn't chat-referenced like R-/T- are, so int id + name is
// enough.
// Sessions are created remotely (projectId/workerId/name only); the owning
// Worker materializes them — minting agentSessionId + git worktree — and PATCHes
// those in. So agentSessionId/worktreePath are nullable until materialized. No
// per-session apiToken anymore: the Worker authenticates all session writes with
// its own token (it created every session).
model Session {
  id             Int       @id @default(autoincrement())
  projectId      Int
  workerId       Int // FK → Worker(id). onDelete Cascade: destroy worker takes its sessions with it.
  mode           String /// 'worker' | 'skill' (collaboration dimension; orthogonal to agent kind)
  name           String
  nameLocked     Boolean   @default(false) // true once a human names it; suppresses auto-title. Server-internal (not in SessionView).
  agentKind      String /// 'claude-code' (v0). Future: 'codex' | …
  agentSessionId String? // claude-code: UUID; null until the Worker materializes.
  worktreePath   String? // local cwd on the worker; null until the Worker materializes.
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker  Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([agentKind, agentSessionId])
  @@index([projectId])
  @@index([workerId])
}

// A Worker is a (project × machine) registration. machineId is a UUID baton
// lazily writes to ~/.local/share/baton/machine-id on the client. name is
// the human handle. apiToken (issued once at register) authenticates the
// persistent worker daemon: its command stream subscription and all session
// writes on behalf of the sessions it owns. Worker rows persist; alive/lastSeen
// belong in memory.
model Worker {
  id        Int      @id @default(autoincrement())
  projectId Int
  machineId String
  name      String
  hostname  String
  apiToken  String   @unique
  createdAt DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessions Session[]

  // No more closedAt: destroy = DELETE row. (projectId, machineId) and
  // (projectId, name) are unconditionally unique now.
  @@unique([projectId, machineId])
  @@unique([projectId, name])
}

// Session events (user_message / sdk_event / turn_* / system) used to live
// here as an append-only log. They were moved out of server storage in 2026
// — content now lives only in each browser's IndexedDB. The server is a
// real-time relay, not a transcript store. Privacy first.
