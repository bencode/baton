// baton persistence (M1, SQLite via Prisma). Collaboration dimension only: Workspace / Project / Requirement / Task.
// PKs are INT autoincrement; Requirement/Task carry a project-scoped human code (R-N / T-N). The
// next number per kind lives in CodeCounter rows so Project's domain stays free of counter state.
// Array/object fields are stored as JSON text, (de)serialized by the Store mapping layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// A back-office login user (username/password → signed session cookie). Added
// pre-deploy. Auth is enforced only once ≥1 user row exists: seed one to lock
// production; an empty table leaves the API open (dev + CLI/bridge convenience).
// passwordHash is a scrypt "saltHex:hashHex" pair (see src/auth/password.ts).
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  // Optional personal access token (like a GitHub PAT) for machine clients
  // (the DingTalk bridge, CLI) — sent as `Authorization: Bearer <token>`. Minted
  // out-of-band (seed-token script); null until generated. 32-byte random ⇒
  // effectively unique; @@index (not @unique) keeps migrate non-interactive.
  apiToken     String?
  // Admin sees every workspace (bypasses domain scope). Non-admins see only the
  // workspaces they're bound to via UserWorkspace. Seed users are created admin.
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  workspaces UserWorkspace[]
  @@index([apiToken])
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  projects Project[]
  members  UserWorkspace[]
  channels Channel[]
}

// User ↔ Workspace membership (the domain-isolation binding). Pure membership,
// no role. Composite PK is the uniqueness constraint; both sides cascade.
model UserWorkspace {
  userId      Int
  workspaceId Int
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
  @@index([workspaceId])
}

model Project {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  name        String
  description String?
  createdAt   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requirements Requirement[]
  tasks        Task[]
  sessions     Session[]
  workers      Worker[]
  counters     CodeCounter[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model CodeCounter {
  projectId Int
  kind      String // 'requirement' | 'task' — Session no longer has a code (int id only)
  next      Int    @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, kind])
}

model Requirement {
  id          Int      @id @default(autoincrement())
  projectId   Int
  code        String // 'R-1', 'R-2', ...
  title       String
  description String?
  body        String? // detailed content (Markdown)
  resources   String   @default("[]") // JSON ResourceRef[]
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([status])
}

model Task {
  id            Int      @id @default(autoincrement())
  requirementId Int
  projectId     Int // denorm to enable DB-level (projectId, code) UNIQUE
  code          String // 'T-1', 'T-2', ...
  title         String
  body          String? // detailed task content (Markdown)
  dependsOn     String   @default("[]") // JSON Id[] (int FK references)
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requirement Requirement   @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments    TaskComment[]

  @@unique([projectId, code])
  @@index([requirementId])
  @@index([projectId])
  @@index([status])
}

// Append-only comment log on a Task — the collaboration substrate (progress,
// next steps, hand-off notes). A child table, not a JSON column on Task: a
// comment is append semantics (single INSERT, immutable, naturally ordered),
// not the replace semantics of a value field like dependsOn. workerId is a
// soft attribution hint (no FK): null = a human via the UI, set = the
// worker/agent that wrote it. File payloads never live here — they travel over
// chat/Send; Task carries only text + git references.
model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  body      String
  workerId  Int?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// A Session models one agent conversation, physically pinned to a Worker
// (= a specific machine) and to that machine's agent session file. The pinning
// is non-movable: `claude --resume <agentSessionId>` only works on the worker
// where the agent session file was first created (~/.claude/projects/...).
//
// agentKind is the agent flavour (currently 'claude-code'; 'codex' etc. later);
// agentSessionId is the agent's own session reference (a UUID for claude-code).
//
// `state` (idle/busy/closed) and `heartbeatAt` from M2.5 are gone — busy is
// derived from SessionEvent log, alive from worker liveness. `code` (S-N) is
// dropped: Session isn't chat-referenced like R-/T- are, so int id + name is
// enough.
// Sessions are created remotely (projectId/workerId/name only); the owning
// Worker materializes them — minting agentSessionId + git worktree — and PATCHes
// those in. So agentSessionId/worktreePath are nullable until materialized. No
// per-session apiToken anymore: the Worker authenticates all session writes with
// its own token (it created every session).
model Session {
  id             Int       @id @default(autoincrement())
  projectId      Int
  workerId       Int // FK → Worker(id). onDelete Cascade: destroy worker takes its sessions with it.
  mode           String /// 'worker' | 'skill' (collaboration dimension; orthogonal to agent kind)
  name           String
  nameLocked     Boolean   @default(false) // true once a human names it; suppresses auto-title. Server-internal (not in SessionView).
  agentKind      String /// 'claude-code' (v0). Future: 'codex' | …
  agentSessionId String? // claude-code: UUID; null until the Worker materializes.
  worktreePath   String? // local cwd on the worker; null until the Worker materializes.
  shareToken     String? // unguessable key for the standalone /s/:token page; null on legacy rows (32-byte random ⇒ effectively unique)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Last time someone sent this session a message (touched on each user_message).
  // updatedAt only bumps on row writes (rename/materialize) and can't be set
  // manually (@updatedAt); this is the honest "last active" for the rail.
  lastActiveAt   DateTime  @default(now())
  // Session-wide read-only "plan mode" toggle. When true the worker runs each
  // turn with the SDK's permissionMode:'plan' (propose, no edits). Persisted so
  // it survives reloads and stays in sync across clients; surfaced on SessionView.
  planMode       Boolean   @default(false)
  // Model override for this session's turns (web /model). Passed verbatim to
  // the SDK's options.model; null = the CLI default model.
  model          String?

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker  Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  events  SessionEvent[]
  loops   Loop[]

  @@unique([agentKind, agentSessionId])
  @@index([projectId])
  @@index([workerId])
  @@index([shareToken])
}

// A Worker is a (project × machine) registration. machineId is a UUID baton
// lazily writes to ~/.local/share/baton/machine-id on the client. name is
// the human handle. apiToken (issued once at register) authenticates the
// persistent worker daemon: its command stream subscription and all session
// writes on behalf of the sessions it owns. Worker rows persist; alive/lastSeen
// belong in memory.
model Worker {
  id        Int      @id @default(autoincrement())
  projectId Int
  agentKind String   @default("claude-code")
  machineId String
  name      String
  hostname  String
  apiToken  String   @unique
  createdAt DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sessions Session[]

  // No more closedAt: destroy = DELETE row. (projectId, machineId) and
  // (projectId, name) are unconditionally unique now.
  @@unique([projectId, machineId])
  @@unique([projectId, name])
}

// Append-only transcript of a Session — user_message / sdk_event / turn_* /
// system. Persisted server-side again (the browser-IndexedDB-only model was
// dropped): the server is the single source of truth, so any client — a
// reloaded tab, another device, a DingTalk-opened link, a headless run — sees
// the full history. `sequence` is per-session (0-based, assigned in a tx);
// payload is JSON text, (de)serialized by the Store mapping layer. Retention /
// auth come later; v0 keeps everything.
model SessionEvent {
  id        Int      @id @default(autoincrement())
  sessionId Int
  sequence  Int
  type      String /// 'user_message' | 'sdk_event' | 'turn_start' | 'turn_complete' | 'turn_error' | 'system'
  payload   String // JSON
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId])
}

// A Loop is a recurring scheduled wake-up for a Session: every `intervalSec`
// seconds the server sends `message` to the session via the normal send path
// (auto-resume spins the worker up). Recurring only; `enabled` pauses it without
// deleting. Best-effort: if the worker is offline at fire time the beat is
// skipped (lastStatus='skipped_offline'), not queued — nextRunAt advances from
// now so missed beats don't pile up. Cascades away with its Session.
model Loop {
  id          Int       @id @default(autoincrement())
  sessionId   Int
  name        String? // optional human label for the rail/config list
  message     String // sent verbatim to the session each beat
  intervalSec Int // beat period in seconds (UI enters minutes/hours/days)
  enabled     Boolean   @default(true)
  nextRunAt   DateTime // next scheduled fire; created as now + intervalSec
  lastRunAt   DateTime? // last actual fire (null until first beat)
  lastStatus  String? /// 'ok' | 'skipped_offline'
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([enabled, nextRunAt])
}

// An N-party live chat room — the multi-agent evolution of the 2-party relay
// (see the old in-memory relay-bus). Two layers: it BELONGS to a Workspace
// (creation + listing are gated by workspace membership, so the back-office can
// manage its rooms and nothing anonymous can inject channels), but PARTICIPATION
// is open on the unguessable id itself — the channel uuid IS the capability: whoever
// holds it can read, write, and join over the id-only API, no account needed (that's
// how an invited outside agent/person joins from anywhere). Unlike the relay, messages
// persist (history survives restart and replays into the web UI). Presence (who's
// online) stays in memory.
model Channel {
  id          String   @id @default(uuid())
  workspaceId Int
  title       String?
  // Free-text self-description (purpose / topic / how to participate). Returned
  // by GET /channels/:id so a newcomer can orient with one call.
  description String?
  createdAt   DateTime @default(now())

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  ChannelMessage[]

  @@index([workspaceId])
}

// Append-only message log on a Channel. Mirrors SessionEvent: per-channel `seq`
// assigned in a tx (read max + 1) so concurrent senders can't collide on the
// (channelId, seq) unique key; `seq` doubles as the replay cursor (?since=).
// `sender`/`senderKind` are soft attribution (no FK). `to` is a JSON array of
// recipient names (null = broadcast to the room).
model ChannelMessage {
  id         Int      @id @default(autoincrement())
  channelId  String
  seq        Int
  sender     String
  senderKind String   @default("agent")
  text       String
  to         String?
  attachments String? // JSON Attachment[] (null = none)
  createdAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, seq])
  @@index([channelId])
}
